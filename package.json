{
    "name": "raphaeltheriault.com",
    "version": "1.0.0",
    "description": "Personal website",
    "repository": "https://github.com/raftario/raftario.github.io",
    "homepage": "https://raphaeltheriault.com",
    "author": "Raphaël Thériault <raphael_theriault@outlook.com>",
    "license": "MIT",
    "main": "README.md",
    "scripts": {
        "dev": "vuepress dev",
        "build": "vuepress build",
        "lint": "eslint --fix **/*.{vue,js} && prettier --write **/*.{json,md,yml,html}"
    },
    "dependencies": {
        "babel-eslint": "^10.0.3",
        "eslint": "^6.7.2",
        "eslint-config-prettier": "^6.7.0",
        "eslint-plugin-prettier": "^3.1.1",
        "eslint-plugin-vue": "^6.0.1",
        "husky": "^3.1.0",
        "lint-staged": "^9.5.0",
        "prettier": "^1.19.1",
        "vuepress": "^1.2.0"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "lint-staged": {
        "*.{vue,js}": [
            "eslint --fix",
            "git add"
        ],
        "*.{json,md,yml,html}": [
            "prettier --write",
            "git add"
        ]
    }
}
